export io.github.lishangbu.avalon.dataset.entity.EvolutionTrigger

EvolutionTriggerView {
    id
    internalName
    name
}

input SaveEvolutionTriggerInput {
    internalName
    name
}

input UpdateEvolutionTriggerInput {
    id!
    internalName
    name
}

specification EvolutionTriggerSpecification {
    id
    like/i(internalName)
    like/i(name)
}
