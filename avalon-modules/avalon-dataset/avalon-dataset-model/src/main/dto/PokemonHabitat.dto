export io.github.lishangbu.avalon.dataset.entity.PokemonHabitat
import jakarta.validation.constraints.NotBlank

PokemonHabitatView {
    id
    internalName
    name
}

input SavePokemonHabitatInput {
    @NotBlank
    internalName
    @NotBlank
    name
}

input UpdatePokemonHabitatInput {
    id!
    @NotBlank
    internalName
    @NotBlank
    name
}

specification PokemonHabitatSpecification {
    id
    like/i(internalName)
    like/i(name)
}
