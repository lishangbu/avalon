export io.github.lishangbu.avalon.dataset.entity.BerryFirmness
import jakarta.validation.constraints.NotBlank

BerryFirmnessView {
    id
    internalName
    name
}

input SaveBerryFirmnessInput {
    @NotBlank
    internalName
    @NotBlank
    name
}

input UpdateBerryFirmnessInput {
    id!
    @NotBlank
    internalName
    @NotBlank
    name
}

specification BerryFirmnessSpecification {
    id
    like/i(internalName)
    like/i(name)
}
