export io.github.lishangbu.avalon.dataset.entity.MoveAilment
import jakarta.validation.constraints.NotBlank

MoveAilmentView {
    id
    internalName
    name
}

input SaveMoveAilmentInput {
    @NotBlank
    internalName
    @NotBlank
    name
}

input UpdateMoveAilmentInput {
    id!
    @NotBlank
    internalName
    @NotBlank
    name
}

specification MoveAilmentSpecification {
    id
    like/i(internalName)
    like/i(name)
}
