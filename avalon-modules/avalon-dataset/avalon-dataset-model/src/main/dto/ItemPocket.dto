export io.github.lishangbu.avalon.dataset.entity.ItemPocket
import jakarta.validation.constraints.NotBlank

ItemPocketView {
    id
    internalName
    name
}

input SaveItemPocketInput {
    @NotBlank
    internalName
    @NotBlank
    name
}

input UpdateItemPocketInput {
    id!
    @NotBlank
    internalName
    @NotBlank
    name
}

specification ItemPocketSpecification {
    id
    like/i(internalName)
    like/i(name)
}
