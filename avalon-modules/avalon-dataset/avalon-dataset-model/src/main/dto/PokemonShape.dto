export io.github.lishangbu.avalon.dataset.entity.PokemonShape
import jakarta.validation.constraints.NotBlank

PokemonShapeView {
    id
    internalName
    name
}

input SavePokemonShapeInput {
    @NotBlank
    internalName
    @NotBlank
    name
}

input UpdatePokemonShapeInput {
    id!
    @NotBlank
    internalName
    @NotBlank
    name
}

specification PokemonShapeSpecification {
    id
    like/i(internalName)
    like/i(name)
}
