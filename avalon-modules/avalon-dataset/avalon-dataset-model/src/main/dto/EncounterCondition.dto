export io.github.lishangbu.avalon.dataset.entity.EncounterCondition
import jakarta.validation.constraints.NotBlank

EncounterConditionView {
    id
    internalName
    name
}

input SaveEncounterConditionInput {
    @NotBlank
    internalName
    @NotBlank
    name
}

input UpdateEncounterConditionInput {
    id!
    @NotBlank
    internalName
    @NotBlank
    name
}

specification EncounterConditionSpecification {
    id
    like/i(internalName)
    like/i(name)
}
