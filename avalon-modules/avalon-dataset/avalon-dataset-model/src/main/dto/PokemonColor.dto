export io.github.lishangbu.avalon.dataset.entity.PokemonColor
import jakarta.validation.constraints.NotBlank

PokemonColorView {
    id
    internalName
    name
}

input SavePokemonColorInput {
    @NotBlank
    internalName
    @NotBlank
    name
}

input UpdatePokemonColorInput {
    id!
    @NotBlank
    internalName
    @NotBlank
    name
}

specification PokemonColorSpecification {
    id
    like/i(internalName)
    like/i(name)
}
