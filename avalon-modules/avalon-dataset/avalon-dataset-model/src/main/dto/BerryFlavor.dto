export io.github.lishangbu.avalon.dataset.entity.BerryFlavor
import jakarta.validation.constraints.NotBlank

BerryFlavorView {
    id
    internalName
    name
}

input SaveBerryFlavorInput {
    @NotBlank
    internalName
    @NotBlank
    name
}

input UpdateBerryFlavorInput {
    id!
    @NotBlank
    internalName
    @NotBlank
    name
}

specification BerryFlavorSpecification {
    id
    like/i(internalName)
    like/i(name)
}
