export io.github.lishangbu.avalon.dataset.entity.Gender
import jakarta.validation.constraints.NotBlank

GenderView {
    id
    internalName
    name
}

input SaveGenderInput {
    @NotBlank
    internalName
    @NotBlank
    name
}

input UpdateGenderInput {
    id!
    @NotBlank
    internalName
    @NotBlank
    name
}

specification GenderSpecification {
    id
    like/i(internalName)
    like/i(name)
}
